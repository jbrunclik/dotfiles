[include]
    path = ~/.gitconfig.local

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[merge]
    conflictStyle = zdiff3

[rerere]
    enabled = true

[init]
    defaultBranch = main

[diff]
    algorithm = histogram
